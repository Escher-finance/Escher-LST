const unbondEbabyFromEthToBabylon = async (signer: ethers.Wallet, amount: bigint) => {
    let sender = await signer.getAddress();
    let ucs03address = "0x5fbe74a283f7954f10aa04c2edf55578811aeb03";
    let channelId: bigint = BigInt(1); // eth channel id to babylon mainnet is 1
    const denomAddress = "0x70df20655b3e294facb436383435754dbee3cd70"; //erc20 ebaby on Eth
    const receiver = "bbn1m7zr5jw4k9z22r9ajggf4ucalwy7uxvu9gkw6tnsmv42lvjpkwasagek5g"; // escher lst contract on babylon
    let quoteToken: Address = "0x62626e3173376a7a7a37637975716d793578707230377965706b61356e676b7465787366657275326372347865777738393766746a373773763330663573"; //hex of cw20 ebaby on babylon
    let baseTokenSymbol = "eBABY";
    let baseTokenName = "ebbn";
    let baseTokenDecimals = 6;
    let baseTokenPath = BigInt(1);
    let salt = getSalt();
    console.log(salt);

    //approve ucs03 contract to transfer first
    const erc20Contract = new ethers.Contract(denomAddress, erc20Abi, signer);
    const resp = await erc20Contract.approve(ucs03address, amount);
    console.log(resp);

    let txReceipt = await resp.wait();
    console.log(txReceipt);

    let payload = {
        unbond: { amount: amount.toString() }
    };
    let instruction =
        transferAndCallInstruction(baseTokenPath, sender.toLowerCase(), receiver, denomAddress, amount, baseTokenSymbol, baseTokenName, baseTokenDecimals, quoteToken, amount, payload);

    console.log("instruction", JSON.stringify(instruction));


    const ucs03Contract = new ethers.Contract(ucs03address, ucs03abi, signer);

    const transferAndCallRes = await ucs03Contract.send(
        channelId,
        0,
        getTimeoutInNanoseconds24HoursFromNow(),
        salt,
        {
            opcode: 2,
            version: 0,
            operand: Instruction.encodeAbi(instruction),
        },
        { gasLimit: 500000 } // Adjust gas limit as needed
    );

    console.log(transferAndCallRes);
    let transferAndCallReceipt = await transferAndCallRes.wait();
    console.log(transferAndCallReceipt);
}